rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read profiles for the coach picklist
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read and write saas_data (RBAC handled mostly in UI right now)
    match /saas_data/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
